    "inputDescriptor": [
        {
            "name": "displayBackground", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Environment"],
            "description": "Controls whether any environment background is rendered."
        },
        {
            "name": "gradient", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Environment"],
            "description": "Renders a spherical gradient as the background."
        },
        {
            "name": "skybox", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Environment"],
            "description": "Renders a cubemap skybox as the background."
        },
        {
            "name": "atmosphere", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Environment"],
            "description": "Renders a procedural physically-based atmosphere."
        },
        {
            "name": "brightness", "type": "float", "nativeType": "float",
            "default": 1.0, "categories": ["Environment"],
            "description": "Brightness multiplier for the rendered background."
        },
        {
            "name": "ambientIntensity", "type": "float", "nativeType": "float",
            "default": 1.0, "categories": ["Environment"],
            "description": "Ambient light intensity contributed by the environment."
        },
        {
            "name": "opaque", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Rendering"],
            "description": "Enables rendering of opaque geometry."
        },
        {
            "name": "transparent", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Rendering"],
            "description": "Enables rendering of transparent geometry."
        },
        {
            "name": "decals", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Rendering"],
            "description": "Enables decal rendering on opaque surfaces."
        },
        {
            "name": "enableGeometryCulling", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Rendering"],
            "description": "Toggles scene geometry frustum culling."
        },
        {
            "name": "selectionOutlines", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Editing"],
            "description": "Renders outlines around selected objects."
        },
        {
            "name": "reflectGradient", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Rendering", "Reflection"],
            "description": "Use the gradient environment as an indirect reflection source."
        },
        {
            "name": "reflectSkybox", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Rendering", "Reflection"],
            "description": "Use the skybox cubemap as an indirect reflection source."
        },
        {
            "name": "reflectAtmosphere", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Rendering", "Reflection"],
            "description": "Use the procedural atmosphere as an indirect reflection source."
        },
        {
            "name": "backgroundReflectionFactor", "type": "float", "nativeType": "float",
            "default": 1.0, "categories": ["Rendering", "Reflection"],
            "description": "Intensity multiplier for environment-based indirect lighting."
        },
        {
            "name": "fog", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Post-processing"],
            "description": "Enables height and distance based volumetric fog."
        },
        {
            "name": "fogColor", "type": "float", "nativeType": "float",
            "default": 0.5, "categories": ["Post-processing"],
            "description": "Fog scattering color intensity."
        },
        {
            "name": "fogDensity", "type": "float", "nativeType": "float",
            "default": 0.01, "categories": ["Post-processing"],
            "description": "Volumetric fog extinction density."
        },
        {
            "name": "bloom", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Post-processing"],
            "description": "Enables bloom glow on bright surfaces."
        },
        {
            "name": "bloomThreshold", "type": "float", "nativeType": "float",
            "default": 1.0, "categories": ["Post-processing"],
            "description": "Luminance threshold above which bloom activates."
        },
        {
            "name": "bloomStrength", "type": "float", "nativeType": "float",
            "default": 0.4, "categories": ["Post-processing"],
            "description": "Bloom intensity multiplier."
        },
        {
            "name": "colorGrading", "type": "bool", "nativeType": "int32_t",
            "default": true, "categories": ["Post-processing"],
            "description": "Enables LUT-based color grading."
        },
        {
            "name": "tonemapBackground", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Post-processing"],
            "description": "Applies tonemapping to the background layer as well as geometry."
        },
        {
            "name": "exposure", "type": "float", "nativeType": "float",
            "default": 1.0, "categories": ["Post-processing"],
            "description": "Scene exposure in EV stops applied during tonemapping."
        },
        {
            "name": "grid", "type": "bool", "nativeType": "int32_t",
            "default": false, "categories": ["Editing"],
            "description": "Renders a world-space reference grid."
        },
        {
            "name": "gridHeight", "type": "float", "nativeType": "float",
            "default": 0.0, "categories": ["Editing"],
            "description": "World-space Y height at which the reference grid is drawn."
        }
    ],

